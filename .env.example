# ─────────────────────────────────────────────────
# TradeArena Environment Variables
# Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────

# Alpha Vantage (stocks, commodities, forex backup)
# Free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ExchangeRate API (live forex rates for 170+ pairs)
# Free key at: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here

# FRED API (US Treasury bond yields)
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# CoinGecko (crypto — works without key on free tier)
# Optional key at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# ─── App Settings ───────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173

# Starting balance in USD (default 100,000)
STARTING_BALANCE=100000
DEFAULT_CURRENCY=USD
